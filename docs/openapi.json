{"openapi":"3.0.1","info":{"title":"Learning Bot API","description":"REST API для Telegram Mini App (Angular фронтенд).\n\n**Авторизация:** каждый запрос к `/api/v1/**` требует заголовок `X-Telegram-Init-Data` — строка `initData` из `window.Telegram.WebApp.initData`.\nБэкенд проверяет HMAC-подпись с помощью `TELEGRAM_BOT_TOKEN`.\n\n**Пользователь:** `user.id` из initData используется как ключ прогресса в БД.\n\n**Ошибки:** `401` — невалидный/отсутствующий initData; `404` — ресурс не найден.\n","contact":{"name":"Learning Bot","url":"https://github.com/SpidMachine/789"},"version":"v1"},"servers":[{"url":"http://localhost:8080","description":"Local dev"},{"url":"/","description":"Current host"}],"security":[{"TelegramInitData":[]}],"tags":[{"name":"Auth","description":"Проверка авторизации и профиль Telegram-пользователя"},{"name":"Catalog","description":"Каталог тем и контента"},{"name":"User","description":"Закладки, достижения и настройки"},{"name":"Session","description":"Сессии из 5 вопросов"},{"name":"Quiz","description":"Подбор вопросов и проверка ответов"},{"name":"Stats","description":"Статистика обучения"}],"paths":{"/api/v1/sessions":{"post":{"tags":["Session"],"summary":"Начать сессию","description":"Создаёт сессию из 5 вопросов (размер задаётся `app.session-size`). Возвращает текущее состояние с первым вопросом.","operationId":"start","parameters":[{"name":"user","in":"query","required":true,"schema":{"$ref":"#/components/schemas/TelegramUser"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/StartSessionRequestDto"}}}},"responses":{"200":{"description":"Сессия создана","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SessionDto"}}}}},"security":[{"TelegramInitData":[]}]}},"/api/v1/quiz/review":{"post":{"tags":["Quiz"],"summary":"Вопрос на повторение","description":"Возвращает случайный вопрос из очереди spaced repetition (просроченные `next_review_at`).","operationId":"review","parameters":[{"name":"user","in":"query","required":true,"schema":{"$ref":"#/components/schemas/TelegramUser"}}],"responses":{"404":{"description":"Нет вопросов на повторение","content":{"*/*":{"schema":{"$ref":"#/components/schemas/QuizPickDto"}}}},"200":{"description":"Вопрос на повторение","content":{"*/*":{"schema":{"$ref":"#/components/schemas/QuizPickDto"}}}}},"security":[{"TelegramInitData":[]}]}},"/api/v1/quiz/pick":{"post":{"tags":["Quiz"],"summary":"Случайный вопрос","description":"Умный подбор: сначала просроченные (SRS), затем слабые, новые, случайные.\nТело запроса опционально — без фильтров вернёт любой подходящий вопрос.\n**Важно:** поле `correct` в ответе отсутствует — индекс правильного ответа\nвозвращается только в `POST /quiz/answers`.\n","operationId":"pick","parameters":[{"name":"user","in":"query","required":true,"schema":{"$ref":"#/components/schemas/TelegramUser"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/QuizPickRequestDto"}}}},"responses":{"404":{"description":"Нет подходящих вопросов","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiErrorDto"}}}},"200":{"description":"Вопрос подобран","content":{"*/*":{"schema":{"$ref":"#/components/schemas/QuizPickDto"}}}}},"security":[{"TelegramInitData":[]}]}},"/api/v1/quiz/answers":{"post":{"tags":["Quiz"],"summary":"Отправить ответ","description":"Сохраняет ответ, обновляет SRS, статистику и недельный прогресс.\nЕсли активна сессия ×5 — автоматически продвигает её (`advanceSession`).\nМожет разблокировать достижения (поле `newAchievements`).\n","operationId":"answer","parameters":[{"name":"user","in":"query","required":true,"schema":{"$ref":"#/components/schemas/TelegramUser"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AnswerRequestDto"}}},"required":true},"responses":{"200":{"description":"Ответ проверен","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AnswerResultDto"}}}},"404":{"description":"Вопрос не найден","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AnswerResultDto"}}}}},"security":[{"TelegramInitData":[]}]}},"/api/v1/bookmarks/{itemId}":{"post":{"tags":["User"],"summary":"Добавить закладку","description":"Идемпотентно: повторный вызов не создаёт дубликат.","operationId":"addBookmark","parameters":[{"name":"user","in":"query","required":true,"schema":{"$ref":"#/components/schemas/TelegramUser"}},{"name":"itemId","in":"path","description":"ID вопроса","required":true,"schema":{"type":"string"},"example":"spring_01"}],"responses":{"200":{"description":"Закладка добавлена"}},"security":[{"TelegramInitData":[]}]}},"/api/v1/settings":{"get":{"tags":["User"],"summary":"Настройки пользователя","operationId":"settings","parameters":[{"name":"user","in":"query","required":true,"schema":{"$ref":"#/components/schemas/TelegramUser"}}],"responses":{"200":{"description":"Текущие настройки","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SettingsDto"}}}}},"security":[{"TelegramInitData":[]}]},"patch":{"tags":["User"],"summary":"Обновить настройки","description":"Частичное обновление: передавай только изменяемые поля.","operationId":"updateSettings","parameters":[{"name":"user","in":"query","required":true,"schema":{"$ref":"#/components/schemas/TelegramUser"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UpdateSettingsRequestDto"}}},"required":true},"responses":{"200":{"description":"Обновлённые настройки","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SettingsDto"}}}}},"security":[{"TelegramInitData":[]}]}},"/api/v1/topics":{"get":{"tags":["Catalog"],"summary":"Список тем","description":"Возвращает все учебные темы с emoji и ключами для фильтрации квиза.","operationId":"list","responses":{"401":{"description":"Невалидный initData","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiErrorDto"}}}},"200":{"description":"Список тем","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/TopicDto"}}}}}},"security":[{"TelegramInitData":[]}]}},"/api/v1/stats":{"get":{"tags":["Stats"],"summary":"Статистика пользователя","description":"Точность, серия дней, прогресс недели, активность по дням и разбивка по темам.","operationId":"stats","parameters":[{"name":"user","in":"query","required":true,"schema":{"$ref":"#/components/schemas/TelegramUser"}}],"responses":{"200":{"description":"Статистика","content":{"*/*":{"schema":{"$ref":"#/components/schemas/StatsDto"}}}}},"security":[{"TelegramInitData":[]}]}},"/api/v1/sessions/current":{"get":{"tags":["Session"],"summary":"Текущая сессия","description":"Возвращает прогресс и текущий вопрос. `finished=true` когда все вопросы отвечены.","operationId":"current","parameters":[{"name":"user","in":"query","required":true,"schema":{"$ref":"#/components/schemas/TelegramUser"}}],"responses":{"404":{"description":"Сессия не начата","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiErrorDto"}}}},"200":{"description":"Сессия активна","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SessionDto"}}}}},"security":[{"TelegramInitData":[]}]}},"/api/v1/quiz/items/{itemId}":{"get":{"tags":["Quiz"],"summary":"Вопрос по ID","description":"Возвращает вопрос без правильного ответа (для отображения в UI).","operationId":"getItem","parameters":[{"name":"itemId","in":"path","description":"ID вопроса","required":true,"schema":{"type":"string"},"example":"spring_01"}],"responses":{"200":{"description":"Вопрос найден","content":{"*/*":{"schema":{"$ref":"#/components/schemas/QuestionDto"}}}},"404":{"description":"Вопрос не найден","content":{"*/*":{"schema":{"$ref":"#/components/schemas/QuestionDto"}}}}},"security":[{"TelegramInitData":[]}]}},"/api/v1/me":{"get":{"tags":["Auth"],"summary":"Текущий пользователь","description":"Проверяет initData и возвращает данные пользователя из Telegram. Создаёт настройки по умолчанию при первом обращении.","operationId":"me","parameters":[{"name":"user","in":"query","required":true,"schema":{"$ref":"#/components/schemas/TelegramUser"}}],"responses":{"401":{"description":"Невалидный initData","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiErrorDto"}}}},"200":{"description":"Пользователь авторизован","content":{"*/*":{"schema":{"$ref":"#/components/schemas/MeDto"}}}}},"security":[{"TelegramInitData":[]}]}},"/api/v1/bookmarks":{"get":{"tags":["User"],"summary":"Список закладок","description":"Вопросы, добавленные пользователем в закладки (без правильного ответа).","operationId":"bookmarks","parameters":[{"name":"user","in":"query","required":true,"schema":{"$ref":"#/components/schemas/TelegramUser"}}],"responses":{"200":{"description":"Список закладок","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/QuestionDto"}}}}}},"security":[{"TelegramInitData":[]}]}},"/api/v1/achievements":{"get":{"tags":["User"],"summary":"Достижения","description":"Список разблокированных достижений (человекочитаемые строки).","operationId":"achievements","parameters":[{"name":"user","in":"query","required":true,"schema":{"$ref":"#/components/schemas/TelegramUser"}}],"responses":{"200":{"description":"Список достижений","content":{"*/*":{"schema":{"type":"array","items":{"type":"string"}}}}}},"security":[{"TelegramInitData":[]}]}}},"components":{"schemas":{"TelegramUser":{"type":"object","properties":{"id":{"type":"integer","format":"int64"},"firstName":{"type":"string"},"lastName":{"type":"string"},"username":{"type":"string"},"languageCode":{"type":"string"}}},"StartSessionRequestDto":{"type":"object","properties":{"mode":{"type":"string","description":"Режим сессии","example":"quiz","default":"quiz"},"topic":{"type":"string","description":"Ограничение по теме (опционально)","example":"java_core"}},"description":"Запрос на старт сессии"},"QuestionDto":{"type":"object","properties":{"id":{"type":"string","example":"spring_01"},"kind":{"type":"string","example":"quiz","enum":["quiz","case","flashcard","config","architecture"]},"topics"