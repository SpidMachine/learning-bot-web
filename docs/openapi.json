ifficultyFilter":{"type":"string"},"weeklyGoal":{"type":"integer","format":"int32"},"weekAnswered":{"type":"integer","format":"int32"}}},"TopicDto":{"type":"object","properties":{"key":{"type":"string"},"title":{"type":"string"},"emoji":{"type":"string"}}},"StatsDto":{"type":"object","properties":{"totalAnswered":{"type":"integer","format":"int32"},"totalCorrect":{"type":"integer","format":"int32"},"accuracy":{"type":"number","format":"double"},"streakDays":{"type":"integer","format":"int32"},"dueForReview":{"type":"integer","format":"int32"},"flashcardsDone":{"type":"integer","format":"int32"},"weeklyGoal":{"type":"integer","format":"int32"},"weekAnswered":{"type":"integer","format":"int32"},"dailyCounts":{"type":"object","additionalProperties":{"type":"integer","format":"int32"}},"topicStats":{"type":"array","items":{"$ref":"#/components/schemas/TopicStatsDto"}}}},"TopicStatsDto":{"type":"object","properties":{"title":{"type":"string"},"answered":{"type":"integer","format":"int32"},"correct":{"type":"integer","format":"int32"},"accuracy":{"type":"number","format":"double"}}},"MeDto":{"type":"object","properties":{"id":{"type":"integer","description":"Telegram user id","format":"int64","example":123456789},"firstName":{"type":"string","example":"Иван"},"username":{"type":"string","example":"ivan_dev"},"miniAppUrl":{"type":"string","description":"URL Mini App из конфигурации бэкенда"}},"description":"Профиль авторизованного Telegram-пользователя"}},"securitySchemes":{"TelegramInitData":{"type":"apiKey","description":"Telegram WebApp initData (query-string формат).\nПример получения на фронте: `Telegram.WebApp.initData`.\nСрок действия подписи: 24 часа с момента `auth_date`.\n","name":"X-Telegram-Init-Data","in":"header"}}}}
